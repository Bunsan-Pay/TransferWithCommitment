{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "signature-transfer-signed-batch.bundle",
  "title": "TWC SignatureTransfer SignedBatchTransfer (exported JSON)",
  "description": "Matches eth-twc-sdk-js/signatureTransfer/batch signedDataSchema. Numeric fields serialized as decimal strings.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "domain",
    "from",
    "details",
    "validAfter",
    "validBefore",
    "batchCommitment",
    "signature"
  ],
  "properties": {
    "domain": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "version", "chainId", "verifyingContract"],
      "properties": {
        "name": { "type": "string" },
        "version": { "type": "string" },
        "chainId": {
          "oneOf": [{ "type": "integer" }, { "type": "string", "pattern": "^[0-9]+$" }]
        },
        "verifyingContract": {
          "type": "string",
          "pattern": "^0x[0-9a-fA-F]{40}$"
        },
        "salt": {
          "type": "string",
          "pattern": "^0x[0-9a-fA-F]{64}$"
        }
      }
    },
    "from": { "type": "string", "pattern": "^0x[0-9a-fA-F]{40}$" },
    "details": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["to", "token", "value", "commitment"],
        "properties": {
          "to": { "type": "string", "pattern": "^0x[0-9a-fA-F]{40}$" },
          "token": { "type": "string", "pattern": "^0x[0-9a-fA-F]{40}$" },
          "value": { "type": "string", "pattern": "^[0-9]+$" },
          "commitment": { "type": "string", "pattern": "^0x[0-9a-fA-F]{64}$" }
        }
      }
    },
    "validAfter": { "type": "string", "pattern": "^[0-9]+$" },
    "validBefore": { "type": "string", "pattern": "^[0-9]+$" },
    "batchCommitment": { "type": "string", "pattern": "^0x[0-9a-fA-F]{64}$" },
    "signature": { "type": "string", "pattern": "^0x[0-9a-fA-F]+$" }
  }
}
