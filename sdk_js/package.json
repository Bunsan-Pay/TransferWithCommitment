{
  "name": "eth-twc-sdk-js",
  "version": "0.1.0",
  "type": "module",
  "files": [
    "dist",
    "README.md",
    "docs"
  ],
  "scripts": {
    "build": "tsup",
    "prepublishOnly": "tsup",
    "test": "bun test test/unit/config.test.ts test/unit/utils.test.ts test/unit/verify.test.ts && bun test --preload ./test/unit/preload.ts test/unit/sign.test.ts test/unit/selfTransfer.test.ts test/unit/signatureTransfer.test.ts",
    "test:integration": "bash test/integration/run.sh"
  },
  "devDependencies": {
    "@types/bun": "1.3.11",
    "prettier": "^3.8.1",
    "tsup": "^8.5.1",
    "typescript": "5.9.3"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "peerDependenciesMeta": {
    "typescript": {
      "optional": true
    }
  },
  "dependencies": {
    "arktype": "^2.2.0",
    "viem": "^2.47.6"
  },
  "exports": {
    "./config": {
      "types": "./dist/config.d.ts",
      "import": "./dist/config.js",
      "require": "./dist/config.cjs"
    },
    "./sign": {
      "types": "./dist/sign.d.ts",
      "import": "./dist/sign.js",
      "require": "./dist/sign.cjs"
    },
    "./verify": {
      "types": "./dist/verify.d.ts",
      "import": "./dist/verify.js",
      "require": "./dist/verify.cjs"
    },
    "./utils": {
      "types": "./dist/utils.d.ts",
      "import": "./dist/utils.js",
      "require": "./dist/utils.cjs"
    },
    "./sendTransaction/selfTransfer": {
      "types": "./dist/sendTransaction/selfTransfer.d.ts",
      "import": "./dist/sendTransaction/selfTransfer.js",
      "require": "./dist/sendTransaction/selfTransfer.cjs"
    },
    "./sendTransaction/signatureTransfer": {
      "types": "./dist/sendTransaction/signatureTransfer.d.ts",
      "import": "./dist/sendTransaction/signatureTransfer.js",
      "require": "./dist/sendTransaction/signatureTransfer.cjs"
    },
    "./types/abi": {
      "types": "./dist/types/abi.d.ts",
      "import": "./dist/types/abi.js",
      "require": "./dist/types/abi.cjs"
    },
    "./types/Eip712Type": {
      "types": "./dist/types/Eip712Type.d.ts",
      "import": "./dist/types/Eip712Type.js",
      "require": "./dist/types/Eip712Type.cjs"
    },
    "./types/transferDetail": {
      "types": "./dist/types/transferDetail.d.ts",
      "import": "./dist/types/transferDetail.js",
      "require": "./dist/types/transferDetail.cjs"
    },
    "./types/signedData": {
      "types": "./dist/types/signedData.d.ts",
      "import": "./dist/types/signedData.js",
      "require": "./dist/types/signedData.cjs"
    },
    "./types/utils": {
      "types": "./dist/types/utils.d.ts",
      "import": "./dist/types/utils.js",
      "require": "./dist/types/utils.cjs"
    },
    "./types/args/signatureTransfer": {
      "types": "./dist/types/args/signatureTransfer.d.ts",
      "import": "./dist/types/args/signatureTransfer.js",
      "require": "./dist/types/args/signatureTransfer.cjs"
    },
    "./types/args/selfTransfer": {
      "types": "./dist/types/args/selfTransfer.d.ts",
      "import": "./dist/types/args/selfTransfer.js",
      "require": "./dist/types/args/selfTransfer.cjs"
    }
  }
}
